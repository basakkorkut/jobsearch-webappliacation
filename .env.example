# ============================================
# DATABASE — Supabase PostgreSQL
# ============================================
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# asyncpg format: postgresql+asyncpg://user:password@host:port/db
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<db-password>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# ============================================
# NOSQL — MongoDB Atlas
# ============================================
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_DB_NAME=jobsearch

# ============================================
# CACHE — Upstash Redis
# ============================================
UPSTASH_REDIS_REST_URL=https://<endpoint>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# ============================================
# QUEUE — CloudAMQP RabbitMQ
# ============================================
RABBITMQ_URL=amqps://<user>:<password>@<host>/<vhost>

# ============================================
# AI — LM Studio (local OpenAI-compatible)
# NOTE: ai-agent-service must run locally; LM Studio must be running.
# ============================================
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen2.5-7b-instruct
LLM_API_KEY=lm-studio

# ============================================
# SERVICE URLs (inter-service communication)
# ============================================
JOB_SERVICE_URL=http://localhost:8001
NOTIFICATION_SERVICE_URL=http://localhost:8002
AI_AGENT_SERVICE_URL=http://localhost:8003
API_GATEWAY_URL=http://localhost:8000

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=http://localhost:5173
VITE_API_GATEWAY_URL=http://localhost:8000
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ============================================
# GENERAL
# ============================================
ENVIRONMENT=development
LOG_LEVEL=INFO
